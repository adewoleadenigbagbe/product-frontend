VITE_API_BASE_URL=http://localhost:3000
VITE_APP_TITLE=Product Frontend

# ===== OIDC / IdentityServer Configuration =====
# IdentityServer authority/discovery endpoint
VITE_OIDC_AUTHORITY=https://localhost:5000

# OIDC Client ID (register this client in your IdentityServer)
VITE_OIDC_CLIENT_ID=product-frontend

# Post-login redirect URI
VITE_OIDC_REDIRECT_URI=http://localhost:5173/auth/callback

# Silent refresh callback URI (for token refresh)
VITE_OIDC_SILENT_REDIRECT_URI=http://localhost:5173/auth/silent-callback

# Post-logout redirect URI
VITE_OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:5173

# Optional: Client secret (only if using confidential client type)
# VITE_OIDC_CLIENT_SECRET=your-client-secret-here
